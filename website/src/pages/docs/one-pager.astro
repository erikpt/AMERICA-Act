---
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';
import { marked } from 'marked';
import DocLayout from '../../layouts/DocLayout.astro';

const __dir = dirname(fileURLToPath(import.meta.url));
const raw = fs.readFileSync(join(__dir, '..', '..', '..', '..', 'AMERICA_Act_One_Pager.md'), 'utf-8');

let html = marked.parse(raw) as string;
// Strip h1 — covered by the layout hero
html = html.replace(/^<h1>.*?<\/h1>\s*/s, '');
// Remove broken image tags (charts are on the /costs page)
html = html.replace(/<img[^>]*>/g, '');
// Replace .md links with website routes
html = html
  .replace(/href="Bill_Text\.md"/g, 'href="/bill"')
  .replace(/href="Financial%20Modeling\/[^"]+"/g, 'href="/docs/financials"');
---

<DocLayout
  title="Executive One-Pager"
  description="Legislative staff briefing summary for the AMERICA Act of 2026. Fiscal snapshot, funding structure, and transition timeline."
  category="Policy Brief"
>
  <div class="mb-6 bg-teal/5 border border-teal/20 rounded-lg px-5 py-4 text-sm text-gray-600 print:hidden">
    This is the policy-focused summary for legislators and staff. For the public-facing version, see the
    <a href="/docs/voter-guide" class="text-teal underline">Voter Guide</a>.
    Charts and financial projections are on the <a href="/costs" class="text-teal underline">What You Pay</a> page.
  </div>

  <article
    class="prose prose-base max-w-none
           [&_h2]:text-navy [&_h2]:border-b-2 [&_h2]:border-teal/30 [&_h2]:pb-2 [&_h2]:mt-10
           [&_h3]:text-navy
           [&_strong]:text-navy
           [&_table]:text-sm [&_th]:bg-navy [&_th]:text-white [&_th]:font-semibold
           [&_blockquote]:border-l-teal [&_blockquote]:bg-teal/5 [&_blockquote]:rounded-r-lg [&_blockquote]:py-1
           [&_code]:text-navy [&_code]:bg-gray-100 [&_code]:px-1 [&_code]:rounded"
    set:html={html}
  />

  <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row gap-4 print:hidden">
    <a href="/docs/best-ideas" class="flex-1 bg-navy text-white text-center font-semibold py-3 px-6 rounded-lg hover:bg-navy-light transition-colors">
      What we borrowed from other countries →
    </a>
    <a href="/docs/financials" class="flex-1 border border-gray-300 text-gray-700 text-center font-semibold py-3 px-6 rounded-lg hover:bg-gray-50 transition-colors">
      Financial deep dive →
    </a>
  </div>
</DocLayout>
