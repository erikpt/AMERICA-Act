---
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';
import { marked } from 'marked';
import DocLayout from '../../layouts/DocLayout.astro';

const __dir = dirname(fileURLToPath(import.meta.url));
const raw = fs.readFileSync(join(__dir, '..', '..', '..', '..', 'AMERICA_Act_Voter_Handout.md'), 'utf-8');

let html = marked.parse(raw) as string;
// Strip the h1/h3 title block — the layout hero already shows it
html = html.replace(/^<h1>.*?<\/h1>\s*(<h3>.*?<\/h3>)?\s*/s, '');
---

<DocLayout
  title="AMERICA Act — Plain Language Guide"
  description="What the AMERICA Act means for you and your family. Plain-language summary of coverage, costs, and rights."
  category="Voter Guide"
>
  <article
    class="prose prose-lg max-w-none
           [&_h2]:text-navy [&_h2]:border-b-2 [&_h2]:border-teal/30 [&_h2]:pb-2 [&_h2]:mt-10
           [&_h3]:text-navy [&_h3]:mt-6
           [&_strong]:text-navy
           [&_table]:text-sm [&_th]:bg-navy [&_th]:text-white [&_th]:font-semibold [&_td]:py-2
           [&_hr]:border-gray-200 [&_hr]:my-8"
    set:html={html}
  />

  <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row gap-4 print:hidden">
    <a href="/coverage" class="flex-1 bg-teal text-white text-center font-semibold py-3 px-6 rounded-lg hover:bg-teal/90 transition-colors">
      What's covered in detail →
    </a>
    <a href="/costs" class="flex-1 bg-navy text-white text-center font-semibold py-3 px-6 rounded-lg hover:bg-navy-light transition-colors">
      Cost and funding breakdown →
    </a>
    <a href="/bill" class="flex-1 border border-gray-300 text-gray-700 text-center font-semibold py-3 px-6 rounded-lg hover:bg-gray-50 transition-colors">
      Full bill text →
    </a>
  </div>
</DocLayout>
