---
import fs from 'node:fs';
import { fileURLToPath } from 'node:url';
import { dirname, join } from 'node:path';
import { marked } from 'marked';
import DocLayout from '../../layouts/DocLayout.astro';

const __dir = dirname(fileURLToPath(import.meta.url));
const raw = fs.readFileSync(join(__dir, '..', '..', '..', '..', 'AMERICA_Act_Best_Ideas_OnePager.md'), 'utf-8');

let html = marked.parse(raw) as string;
// Strip h1 and italicized subtitle — covered by layout hero
html = html.replace(/^<h1>.*?<\/h1>\s*(<p><em>.*?<\/em><\/p>)?\s*/s, '');
---

<DocLayout
  title="Best Ideas from Around the World"
  description="How the AMERICA Act borrows proven healthcare reforms from France, Canada, Portugal, and other high-performing systems — adapted for the United States."
  category="Policy Research"
>
  <article
    class="prose prose-lg max-w-none
           [&_h2]:text-navy [&_h2]:border-b-2 [&_h2]:border-teal/30 [&_h2]:pb-2 [&_h2]:mt-10
           [&_h3]:text-navy
           [&_strong]:text-navy
           [&_table]:text-sm [&_th]:bg-navy [&_th]:text-white [&_th]:font-semibold [&_td]:align-top
           [&_blockquote]:border-l-teal [&_blockquote]:bg-teal/5 [&_blockquote]:rounded-r-lg [&_blockquote]:py-1
           [&_hr]:border-gray-200 [&_hr]:my-8"
    set:html={html}
  />

  <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row gap-4 print:hidden">
    <a href="/bill" class="flex-1 bg-navy text-white text-center font-semibold py-3 px-6 rounded-lg hover:bg-navy-light transition-colors">
      Read the full bill →
    </a>
    <a href="/docs/one-pager" class="flex-1 border border-gray-300 text-gray-700 text-center font-semibold py-3 px-6 rounded-lg hover:bg-gray-50 transition-colors">
      Executive one-pager →
    </a>
  </div>
</DocLayout>
