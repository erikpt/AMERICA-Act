---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoPayChart from '../components/CoPayChart.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Timeline from '../components/Timeline.astro';
---

<BaseLayout title="Your Healthcare. Guaranteed.">

  <!-- Hero -->
  <section class="bg-navy text-white py-24 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-block bg-teal/20 text-teal text-sm font-semibold px-4 py-1.5 rounded-full mb-6 tracking-wide uppercase">
        Universal Healthcare Access Act of 2026
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight mb-6">
        Your healthcare.<br />Guaranteed.
      </h1>
      <p class="text-lg sm:text-xl text-blue-200 max-w-2xl mx-auto mb-10 leading-relaxed">
        No networks. No denials. No coverage gaps. Essential care for every American —
        no matter your job, income, or health history.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/coverage"
          class="bg-teal hover:bg-teal/90 text-white font-semibold px-8 py-3 rounded-lg transition-colors text-center"
        >
          See what's covered
        </a>
        <a
          href="/costs"
          class="border border-blue-300 hover:border-white text-blue-200 hover:text-white font-semibold px-8 py-3 rounded-lg transition-colors text-center"
        >
          See what you pay
        </a>
      </div>
    </div>
  </section>

  <!-- Key stats bar -->
  <section class="bg-teal text-white py-8 px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
      <div>
        <div class="text-4xl font-bold">330M+</div>
        <div class="text-teal-100 text-sm mt-1">Americans covered from day one</div>
      </div>
      <div class="border-t sm:border-t-0 sm:border-l border-teal-600 pt-6 sm:pt-0 sm:pl-6">
        <div class="text-4xl font-bold">5%</div>
        <div class="text-teal-100 text-sm mt-1">of your income — the maximum you'll ever pay in a year</div>
      </div>
      <div class="border-t sm:border-t-0 sm:border-l border-teal-600 pt-6 sm:pt-0 sm:pl-6">
        <div class="text-4xl font-bold">$0</div>
        <div class="text-teal-100 text-sm mt-1">for preventive care, vaccines, and kids' wellness visits</div>
      </div>
    </div>
  </section>

  <!-- Benefits cards -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-navy text-center mb-4">What changes for you</h2>
      <p class="text-gray-500 text-center mb-12 max-w-xl mx-auto">
        The same doctors. The same hospitals. Just a simpler system that puts you first.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {[
          {
            icon: '🗺️',
            title: 'See any doctor, anywhere',
            body: 'No networks, no referrals. Any licensed provider in the country takes your coverage.',
          },
          {
            icon: '🔒',
            title: 'Coverage that follows you',
            body: 'Change jobs, start a business, retire early. Your coverage never lapses.',
          },
          {
            icon: '🧠',
            title: 'Mental health built in',
            body: 'Behavioral health, substance use treatment, and dental — not add-ons, not extras.',
          },
          {
            icon: '🚫',
            title: 'No surprise bills',
            body: 'Balance billing is illegal. You pay your co-pay. That\'s the full bill.',
          },
        ].map(({ icon, title, body }) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
            <div class="text-3xl mb-3">{icon}</div>
            <h3 class="font-semibold text-navy mb-2">{title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Co-pay preview -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="text-3xl font-bold text-navy mb-4">What you pay is based on what you earn</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            Co-pays are income-based — lower for working families, higher for higher earners.
            And there's a hard annual cap: <strong class="text-navy">you will never pay more than 5% of your income in a year</strong>,
            no matter how sick you get or how much care you need.
          </p>
          <table class="w-full text-sm border-collapse">
            <thead>
              <tr class="bg-navy text-white text-left">
                <th class="px-3 py-2 rounded-tl-lg font-semibold">Income</th>
                <th class="px-3 py-2 font-semibold">Primary</th>
                <th class="px-3 py-2 font-semibold">Specialist</th>
                <th class="px-3 py-2 rounded-tr-lg font-semibold">ER</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <tr class="bg-teal/5 font-semibold">
                <td class="px-3 py-2.5 text-navy">Under $75k</td>
                <td class="px-3 py-2.5 text-teal font-bold">$0</td>
                <td class="px-3 py-2.5">$25</td>
                <td class="px-3 py-2.5">$50</td>
              </tr>
              <tr>
                <td class="px-3 py-2.5 text-navy">$75k – $200k</td>
                <td class="px-3 py-2.5">$20</td>
                <td class="px-3 py-2.5">$50</td>
                <td class="px-3 py-2.5">$100</td>
              </tr>
              <tr class="bg-gray-50">
                <td class="px-3 py-2.5 text-navy">$200k – $500k</td>
                <td class="px-3 py-2.5">$40</td>
                <td class="px-3 py-2.5">$100</td>
                <td class="px-3 py-2.5">$200</td>
              </tr>
              <tr>
                <td class="px-3 py-2.5 text-navy">Over $500k</td>
                <td class="px-3 py-2.5">$60</td>
                <td class="px-3 py-2.5">$150</td>
                <td class="px-3 py-2.5">$300</td>
              </tr>
            </tbody>
          </table>
          <p class="text-xs text-gray-400 mt-3">Preventive care and children's visits: always $0. <a href="/costs" class="text-teal underline">Full breakdown →</a></p>
        </div>
        <div>
          <CoPayChart />
          <p class="text-xs text-gray-400 mt-3 text-center">Co-pay per visit by income tier and service type. 5% AGI cap applies annually.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-20 px-4 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-navy text-center mb-4">How it works</h2>
      <p class="text-gray-500 text-center mb-10 max-w-xl mx-auto">
        Contributions from workers, employers, and realigned federal programs flow into
        one fund — which pays providers directly.
      </p>
      <HowItWorks />
    </div>
  </section>

  <!-- 5-year timeline -->
  <section class="py-20 px-4">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-navy text-center mb-4">Phased in over 5 years</h2>
      <p class="text-gray-500 text-center mb-12 max-w-xl mx-auto">
        No overnight disruption. Your current coverage continues during the transition.
        If you're in active treatment, you keep your current providers for at least 12 months.
      </p>
      <Timeline />
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="py-20 px-4 bg-navy text-white text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold mb-4">This is a draft. Your input shapes it.</h2>
      <p class="text-blue-200 mb-8 leading-relaxed">
        This legislation is being written in the open. Read the full bill, propose amendments,
        or share your story. Everyone affected by healthcare has a seat at this table.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://github.com/erikpt/UniversalHealthAccessAct/blob/main/Bill_Text.md"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-teal hover:bg-teal/90 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
        >
          Read the full bill
        </a>
        <a
          href="/get-involved"
          class="border border-blue-300 hover:border-white text-blue-200 hover:text-white font-semibold px-8 py-3 rounded-lg transition-colors"
        >
          Get involved
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
